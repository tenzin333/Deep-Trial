{
  "manifest_version": 3,
  "name": "DeepTrail",
  "description": "AI-Powered Research Knowledge Graph",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "activeTab",
    "sidePanel",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel-dist/index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Open DeepTrail"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}