{
  "manifest_version": 3,
  "name": "DeepTrail",
  "description": "AI-Powered Research Knowledge Graph",
  "version": "1.0.3",
  "homepage_url": "https://github.com/tenzin333/deeptrail",
  "permissions": ["activeTab", "tabs", "sidePanel", "storage"],
  "host_permissions": [
    "https://deep-trial.onrender.com/*",
    "http://localhost:8000/*",
    "http://deep-trial.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel-dist/index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon_16.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    },
    "default_title": "Open DeepTrail"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current page to DeepTrail"
    }
  }
}